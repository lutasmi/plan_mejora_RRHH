<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Plan de Mejora RRHH</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react/18.2.0/umd/react.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/react-dom/18.2.0/umd/react-dom.production.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/babel-standalone/7.23.2/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:#0c131c;color:#dde8f0;font-family:system-ui,sans-serif;overflow:hidden;height:100vh}
  input,textarea,select{font-family:inherit}
  ::-webkit-scrollbar{width:5px;height:5px}
  ::-webkit-scrollbar-track{background:#0a1018}
  ::-webkit-scrollbar-thumb{background:#2a3a4a;border-radius:3px}
  input[type=color]{-webkit-appearance:none;border:none}
  input[type=color]::-webkit-color-swatch-wrapper{padding:0}
  input[type=color]::-webkit-color-swatch{border:none;border-radius:2px}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel">
const { useState, useEffect, useRef } = React;

// ── Supabase ──────────────────────────────────────────────────────────────────
const SUPA_URL = "https://dlbysoybuanzfbgbqgwi.supabase.co";
const SUPA_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRsYnlzb3lidWFuemZiZ2JxZ3dpIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY5NTAxNzYsImV4cCI6MjA5MjUyNjE3Nn0.H1te91wXuuqwH0Farbz2Zt5eXeza0rBvlENLxh1Q18E";
const sb = supabase.createClient(SUPA_URL, SUPA_KEY);
const SKEY = "plan-mejora-v1";

async function dbLoad() {
  try {
    const { data } = await sb.from("app_data").select("value").eq("key", SKEY).single();
    return data ? JSON.parse(data.value) : null;
  } catch { return null; }
}
async function dbSave(val) {
  try {
    await sb.from("app_data").upsert({ key: SKEY, value: JSON.stringify(val), updated_at: new Date().toISOString() });
  } catch(e) { console.error("Save error", e); }
}

// ── Constants ─────────────────────────────────────────────────────────────────
const COLS = [
  { id:"pol", label:"Políticas y Procesos",         color:"#1a3870", hl:"#2e5aaa" },
  { id:"dat", label:"Dato y Gobierno",              color:"#0d5038", hl:"#18906a" },
  { id:"tec", label:"Tecnología y Automatización",  color:"#622e00", hl:"#b85c10" },
  { id:"ctl", label:"Control y Cumplimiento",       color:"#42101e", hl:"#982438" },
];
const INIT = {
  rows:[
    {id:"r1",name:"Alta / Contratación"},
    {id:"r2",name:"Onboarding"},
    {id:"r3",name:"Cambios Contractuales"},
    {id:"r4",name:"Retribución y Compensación"},
    {id:"r5",name:"Evaluación del Desempeño"},
    {id:"r6",name:"Formación y Desarrollo"},
    {id:"r7",name:"Promoción y Carrera"},
    {id:"r8",name:"Movilidad Interna"},
    {id:"r9",name:"Expatriación"},
    {id:"r10",name:"Desvinculación / Offboarding"},
  ],
  cards:[],
  owners:[
    {id:"o1",name:"Sin asignar",         color:"#556677"},
    {id:"o2",name:"HR Director",         color:"#e94560"},
    {id:"o3",name:"HR Ops Manager",      color:"#4cc9f0"},
    {id:"o4",name:"Director de Talento", color:"#95d5b2"},
    {id:"o5",name:"Legal / Compliance",  color:"#f5a623"},
    {id:"o6",name:"IT / Sistemas",       color:"#b5838d"},
  ],
  tags:[
    {id:"tg1",name:"Prioritario", color:"#e94560"},
    {id:"tg2",name:"En curso",    color:"#f5a623"},
    {id:"tg3",name:"Pendiente",   color:"#667788"},
    {id:"tg4",name:"Quick win",   color:"#95d5b2"},
    {id:"tg5",name:"Revisión",    color:"#c084fc"},
  ],
};

const uid  = () => Math.random().toString(36).slice(2,8);
const INP  = { background:"#0c1520", border:"1px solid #1c2a3a", color:"#b8ccd8", padding:"6px 8px", fontSize:"11px", borderRadius:2, fontFamily:"inherit", outline:"none", width:"100%", boxSizing:"border-box" };
const BTNS = { background:"transparent", border:"1px solid #2a3a4a", color:"#6a8090", cursor:"pointer", padding:"5px 10px", fontSize:"9px", letterSpacing:"1.5px", borderRadius:2, fontFamily:"inherit" };
const LW = 155;
const CW = 220;

// ── App ───────────────────────────────────────────────────────────────────────
function App() {
  const [D,       setD]       = useState(null);
  const [panel,   setPanel]   = useState(null);
  const [editing, setEditing] = useState(null);
  const [fOwners, setFOwners] = useState([]);
  const [fTags,   setFTags]   = useState([]);
  const [saved,   setSaved]   = useState(true);
  const [loading, setLoading] = useState(true);
  const saveTimer = useRef(null);

  useEffect(() => {
    dbLoad().then(d => { setD(d || INIT); setLoading(false); });
  }, []);

  useEffect(() => {
    if (!D || loading) return;
    setSaved(false);
    if (saveTimer.current) clearTimeout(saveTimer.current);
    saveTimer.current = setTimeout(() => { dbSave(D).then(() => setSaved(true)); }, 1000);
    return () => clearTimeout(saveTimer.current);
  }, [D]);

  const mut = fn => setD(d => { const nd = JSON.parse(JSON.stringify(d)); fn(nd); return nd; });

  const openAdd = (rowId, colId) => {
    const c = { id:uid(), rowId, colId, name:"Nueva entrada", desc:"", url:"", ownerId:"o1", tagIds:[], sw:0, ew:4, deps:[] };
    mut(d => d.cards.push(c));
    setEditing(c); setPanel("card");
  };
  const saveCard = c => { mut(d => { const i=d.cards.findIndex(x=>x.id===c.id); if(i>=0) d.cards[i]=c; }); setEditing(null); setPanel(null); };
  const deleteCard = id => { mut(d => { d.cards=d.cards.filter(c=>c.id!==id).map(c=>({...c,deps:c.deps.filter(x=>x!==id)})); }); setEditing(null); setPanel(null); };
  const addRow    = ()        => mut(d => d.rows.push({id:uid(),name:"Nueva etapa"}));
  const renameRow = (id,name) => mut(d => { const r=d.rows.find(r=>r.id===id); if(r) r.name=name; });
  const deleteRow = id        => mut(d => { d.rows=d.rows.filter(r=>r.id!==id); d.cards=d.cards.filter(c=>c.rowId!==id); });
  const moveRow   = (id,dir)  => mut(d => {
    const i=d.rows.findIndex(r=>r.id===id), ni=i+dir;
    if(ni<0||ni>=d.rows.length) return;
    [d.rows[i],d.rows[ni]]=[d.rows[ni],d.rows[i]];
  });

  const isVisible = c => {
    if(!fOwners.length && !fTags.length) return true;
    return (!fOwners.length||fOwners.includes(c.ownerId)) && (!fTags.length||fTags.some(t=>c.tagIds.includes(t)));
  };
  const hasFilter = fOwners.length>0||fTags.length>0;

  if (loading) return (
    <div style={{height:"100vh",display:"flex",alignItems:"center",justifyContent:"center",flexDirection:"column",gap:16}}>
      <div style={{fontSize:"10px",letterSpacing:"4px",color:"#4cc9f0"}}>CARGANDO</div>
      <div style={{fontSize:"12px",color:"#3a5060"}}>Conectando con la base de datos…</div>
    </div>
  );

  return (
    <div style={{height:"100vh",display:"flex",flexDirection:"column",background:"#0c131c",color:"#dde8f0",overflow:"hidden"}}>
      {/* Header */}
      <div style={{background:"#060d14",borderBottom:"2px solid #1a3050",padding:"10px 16px",flexShrink:0,zIndex:50}}>
        <div style={{display:"flex",alignItems:"center",gap:8,flexWrap:"wrap"}}>
          <div style={{marginRight:4}}>
            <div style={{fontSize:"8px",letterSpacing:"4px",color:"#4cc9f0",marginBottom:2}}>RRHH · TRANSFORMACIÓN</div>
            <div style={{fontSize:"17px",fontWeight:700,letterSpacing:"0.3px"}}>Plan de Mejora</div>
          </div>
          <Divider/>
          <span style={{fontSize:"8px",letterSpacing:"2px",color:"#3a4a5a"}}>OWNER</span>
          {D.owners.filter(o=>o.id!=="o1").map(o => {
            const a=fOwners.includes(o.id);
            return <Pill key={o.id} color={o.color} active={a} onClick={()=>setFOwners(f=>a?f.filter(x=>x!==o.id):[...f,o.id])}>{o.name}</Pill>;
          })}
          <Divider/>
          <span style={{fontSize:"8px",letterSpacing:"2px",color:"#3a4a5a"}}>ETIQUETAS</span>
          {D.tags.map(t => {
            const a=fTags.includes(t.id);
            return <Pill key={t.id} color={t.color} active={a} onClick={()=>setFTags(f=>a?f.filter(x=>x!==t.id):[...f,t.id])}>{t.name}</Pill>;
          })}
          {hasFilter && <button onClick={()=>{setFOwners([]);setFTags([]);}} style={{...BTNS,borderColor:"transparent",color:"#4a6070",fontSize:"10px"}}>× limpiar</button>}
          <div style={{flex:1}}/>
          <span style={{fontSize:"9px",color:saved?"#2a8040":"#b07010",minWidth:80}}>{saved?"✓ guardado":"guardando…"}</span>
          <button onClick={()=>setPanel(p=>p==="settings"?null:"settings")} style={{...BTNS,borderColor:panel==="settings"?"#4cc9f0":"#2a3a4a",color:panel==="settings"?"#4cc9f0":"#6a8090"}}>⚙ Configurar</button>
          <button title="Próximamente: vista Gantt con fechas" style={{...BTNS,opacity:0.4}}>📅 Vista Gantt</button>
          <button onClick={()=>{if(window.confirm("¿Restaurar datos de ejemplo? Se perderán todos los cambios.")) setD(INIT);}} style={{...BTNS,color:"#3a4a5a",borderColor:"#1c2a3a"}}>Reset</button>
        </div>
      </div>

      {/* Body */}
      <div style={{flex:1,display:"flex",overflow:"hidden"}}>
        <div style={{flex:1,overflow:"auto"}}>
          <Matrix D={D} isVisible={isVisible} hasFilter={hasFilter}
            onAdd={openAdd} onEdit={c=>{setEditing({...c});setPanel("card");}}
            onRenameRow={renameRow} onDeleteRow={deleteRow}
            onMoveRow={moveRow} onAddRow={addRow}/>
        </div>
        {panel==="card"     && editing && <CardPanel card={editing} D={D} onSave={saveCard} onDelete={()=>deleteCard(editing.id)} onClose={()=>{setPanel(null);setEditing(null);}}/>}
        {panel==="settings"            && <SettingsPanel D={D} mut={mut} onClose={()=>setPanel(null)}/>}
      </div>
    </div>
  );
}

// ── Matrix ────────────────────────────────────────────────────────────────────
function Matrix({ D, isVisible, hasFilter, onAdd, onEdit, onRenameRow, onDeleteRow, onMoveRow, onAddRow }) {
  const gridCols = `${LW}px repeat(4, minmax(${CW}px,1fr))`;
  return (
    <div style={{display:"grid",gridTemplateColumns:gridCols,minWidth:LW+4*CW}}>
      <div style={{position:"sticky",top:0,left:0,zIndex:52,background:"#060d14",borderRight:"1px solid #1a2a3a",borderBottom:"2px solid #1a3050",padding:"10px 12px",display:"flex",alignItems:"flex-end"}}>
        <span style={{fontSize:"8px",letterSpacing:"2px",color:"#2a3a4a"}}>ETAPA DEL CICLO</span>
      </div>
      {COLS.map((col,ci) => (
        <div key={col.id} style={{position:"sticky",top:0,zIndex:48,background:col.color,borderLeft:"1px solid rgba(0,0,0,0.35)",borderBottom:"2px solid rgba(0,0,0,0.3)",padding:"10px 14px 10px 18px",position:"relative"}}>
          {ci>0 && <div style={{position:"absolute",left:-1,top:"50%",transform:"translateY(-50%)",width:14,height:14,background:"#060d14",borderRadius:"50%",display:"flex",alignItems:"center",justifyContent:"center",zIndex:2,fontSize:"10px",color:"rgba(255,255,255,0.3)"}}>›</div>}
          <div style={{fontSize:"8px",letterSpacing:"2px",color:"rgba(255,255,255,0.38)",marginBottom:4}}>0{ci+1}</div>
          <div style={{fontSize:"12px",fontWeight:700,color:"#fff",lineHeight:1.2}}>{col.label}</div>
        </div>
      ))}

      {D.rows.map((row,ri) => {
        const bg = ri%2===0 ? "#0c131c" : "#0a1018";
        return [
          <div key={"L"+row.id} style={{position:"sticky",left:0,zIndex:22,background:bg,borderRight:"1px solid #1a2a3a",borderBottom:"1px solid #141e2c",padding:"10px 8px",minHeight:100}}>
            <RowLabel row={row} idx={ri} total={D.rows.length} onRename={onRenameRow} onDelete={onDeleteRow} onMove={onMoveRow}/>
          </div>,
          ...COLS.map(col => {
            const cellCards = D.cards.filter(c=>c.rowId===row.id&&c.colId===col.id);
            return (
              <div key={"C"+row.id+col.id} style={{background:bg,borderLeft:"1px solid #141e2c",borderBottom:"1px solid #141e2c",padding:"7px",minHeight:100,display:"flex",flexDirection:"column",gap:5}}>
                {cellCards.map(c => <CardChip key={c.id} card={c} D={D} col={col} visible={isVisible(c)} hasFilter={hasFilter} onClick={()=>onEdit(c)}/>)}
                <button onClick={()=>onAdd(row.id,col.id)} style={{marginTop:"auto",background:"none",border:"1px dashed #1a2a3a",color:"#253545",padding:"4px",fontSize:"11px",cursor:"pointer",borderRadius:2,display:"flex",alignItems:"center",justifyContent:"center",lineHeight:1}}>＋</button>
              </div>
            );
          }),
        ];
      })}

      <div style={{gridColumn:"1/-1",padding:14,display:"flex",justifyContent:"center",borderTop:"1px solid #141e2c"}}>
        <button onClick={onAddRow} style={{...BTNS,borderStyle:"dashed",padding:"7px 36px"}}>+ AÑADIR ETAPA DEL CICLO DE VIDA</button>
      </div>
    </div>
  );
}

// ── Row label ─────────────────────────────────────────────────────────────────
function RowLabel({ row, idx, total, onRename, onDelete, onMove }) {
  const [editing, setEditing] = useState(false);
  const [val,     setVal]     = useState(row.name);
  const commit = () => { onRename(row.id, val||row.name); setEditing(false); };
  return (
    <div style={{display:"flex",flexDirection:"column",height:"100%",gap:6}}>
      {editing
        ? <input value={val} onChange={e=>setVal(e.target.value)} onBlur={commit}
            onKeyDown={e=>{if(e.key==="Enter")commit();if(e.key==="Escape")setEditing(false);}}
            autoFocus style={{...INP,fontSize:"11px",padding:"3px 6px"}}/>
        : <div onClick={()=>{setVal(row.name);setEditing(true);}} style={{fontSize:"11px",fontWeight:600,color:"#8aa0b8",lineHeight:1.35,cursor:"text",flex:1}}>{row.name}</div>
      }
      <div style={{display:"flex",gap:3}}>
        <SmBtn onClick={()=>onMove(row.id,-1)} disabled={idx===0} title="Subir">↑</SmBtn>
        <SmBtn onClick={()=>onMove(row.id,1)} disabled={idx===total-1} title="Bajar">↓</SmBtn>
        <SmBtn onClick={()=>{if(window.confirm(`¿Eliminar "${row.name}" y todas sus entradas?`)) onDelete(row.id);}} danger title="Eliminar">✕</SmBtn>
      </div>
    </div>
  );
}
function SmBtn({ children, onClick, disabled, danger, title }) {
  return (
    <button onClick={disabled?undefined:onClick} title={title}
      style={{background:"none",border:"1px solid #1c2a3a",color:danger?"#5a1a2a":disabled?"#1c2a3a":"#2a3a4a",cursor:disabled?"default":"pointer",padding:"2px 5px",fontSize:"9px",borderRadius:2,lineHeight:1}}>
      {children}
    </button>
  );
}

// ── Card chip ─────────────────────────────────────────────────────────────────
function CardChip({ card, D, col, visible, hasFilter, onClick }) {
  const owner = D.owners.find(o=>o.id===card.ownerId)||D.owners[0];
  const tags  = D.tags.filter(t=>card.tagIds.includes(t.id));
  return (
    <div onClick={onClick} style={{background:"#101c28",border:"1px solid #1c2a3a",borderLeft:`3px solid ${owner.color}`,borderRadius:3,padding:"7px 8px",cursor:"pointer",opacity:hasFilter&&!visible?0.08:1,boxShadow:hasFilter&&visible?`0 0 0 1.5px ${owner.color}60`:"none",transition:"opacity 0.2s,box-shadow 0.15s"}}>
      <div style={{fontSize:"11px",color:"#b0c4d8",lineHeight:1.35,marginBottom:tags.length?5:0}}>{card.name}</div>
      {tags.length>0 && (
        <div style={{display:"flex",gap:3,flexWrap:"wrap"}}>
          {tags.map(t=><span key={t.id} style={{fontSize:"8px",background:t.color+"22",color:t.color,padding:"1px 5px",borderRadius:10,border:`1px solid ${t.color}44`}}>{t.name}</span>)}
        </div>
      )}
      {card.url && <div style={{fontSize:"8px",color:"#2a4a6a",marginTop:4}}>🔗 doc enlazado</div>}
    </div>
  );
}

// ── Card panel ────────────────────────────────────────────────────────────────
function CardPanel({ card, D, onSave, onDelete, onClose }) {
  const [f, setF] = useState({...card});
  const set = (k,v) => setF(p=>({...p,[k]:v}));
  const owner = D.owners.find(o=>o.id===f.ownerId)||D.owners[0];
  const col   = COLS.find(c=>c.id===f.colId);
  const row   = D.rows.find(r=>r.id===f.rowId);

  return (
    <div style={{width:310,background:"#070d14",borderLeft:"2px solid #1a3050",display:"flex",flexDirection:"column",overflow:"hidden",flexShrink:0}}>
      <div style={{padding:"12px 16px",background:col?.color||"#1a3050",display:"flex",justifyContent:"space-between",alignItems:"center",flexShrink:0}}>
        <div>
          <div style={{fontSize:"8px",letterSpacing:"2px",color:"rgba(255,255,255,0.45)",marginBottom:2}}>{row?.name} · {col?.label}</div>
          <div style={{fontSize:"12px",color:"#fff",fontWeight:700}}>Editar entrada</div>
        </div>
        <button onClick={onClose} style={{background:"none",border:"none",color:"rgba(255,255,255,0.4)",cursor:"pointer",fontSize:"20px",lineHeight:1,padding:0}}>✕</button>
      </div>

      <div style={{flex:1,overflow:"auto",padding:16,display:"flex",flexDirection:"column",gap:13}}>
        <Field label="NOMBRE">
          <input value={f.name} onChange={e=>set("name",e.target.value)} style={INP}/>
        </Field>
        <Field label="DESCRIPCIÓN">
          <textarea value={f.desc} onChange={e=>set("desc",e.target.value)} rows={3} placeholder="Describe de qué trata esta entrada…" style={{...INP,resize:"vertical",lineHeight:1.5}}/>
        </Field>
        <Field label="ENLACE / DOCUMENTO (SharePoint, URL…)">
          <input value={f.url} onChange={e=>set("url",e.target.value)} placeholder="https://…" style={INP}/>
          {f.url && <a href={f.url} target="_blank" rel="noreferrer" style={{fontSize:"9px",color:"#4cc9f0",display:"block",marginTop:3}}>↗ abrir enlace</a>}
        </Field>
        <Field label="OWNER / RESPONSABLE">
          <select value={f.ownerId} onChange={e=>set("ownerId",e.target.value)} style={{...INP,color:owner.color}}>
            {D.owners.map(o=><option key={o.id} value={o.id}>{o.name}</option>)}
          </select>
          <div style={{height:3,borderRadius:2,marginTop:5,background:owner.color,transition:"background 0.2s"}}/>
        </Field>
        <Field label="ETIQUETAS">
          <div style={{display:"flex",flexWrap:"wrap",gap:5}}>
            {D.tags.map(t => {
              const sel=f.tagIds.includes(t.id);
              return <Pill key={t.id} color={t.color} active={sel} onClick={()=>set("tagIds",sel?f.tagIds.filter(x=>x!==t.id):[...f.tagIds,t.id])}>{t.name}</Pill>;
            })}
          </div>
        </Field>
        <Field label="DEPENDENCIAS">
          <DepSelect value={f.deps} onChange={v=>set("deps",v)} cards={D.cards} rows={D.rows} currentId={card.id}/>
        </Field>
        <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8}}>
          <Field label="SEMANA INICIO">
            <input type="number" min={0} max={52} value={f.sw} onChange={e=>set("sw",+e.target.value)} style={INP}/>
          </Field>
          <Field label="SEMANA FIN">
            <input type="number" min={0} max={52} value={f.ew} onChange={e=>set("ew",+e.target.value)} style={INP}/>
          </Field>
        </div>
        <div style={{fontSize:"8px",color:"#2a3a4a",marginTop:-8}}>Para la futura vista Gantt con fechas</div>
      </div>

      <div style={{padding:"12px 16px",borderTop:"1px solid #1a2a3a",display:"flex",gap:8,flexShrink:0}}>
        <button onClick={()=>onSave(f)} style={{flex:1,background:"#e94560",border:"none",color:"#fff",padding:"9px",cursor:"pointer",fontSize:"10px",letterSpacing:"2px",borderRadius:2,fontFamily:"inherit",fontWeight:700}}>GUARDAR</button>
        <button onClick={onDelete} title="Eliminar entrada" style={{background:"none",border:"1px solid #2a3a4a",color:"#4a5a6a",padding:"9px 13px",cursor:"pointer",fontSize:"14px",borderRadius:2}}>🗑</button>
      </div>
    </div>
  );
}

// ── Dep select ────────────────────────────────────────────────────────────────
function DepSelect({ value, onChange, cards, rows, currentId }) {
  const [open, setOpen] = useState(false);
  const [q,    setQ]    = useState("");
  const ref = useRef(null);

  useEffect(() => {
    const fn = e => { if(ref.current&&!ref.current.contains(e.target)) setOpen(false); };
    document.addEventListener("mousedown",fn);
    return () => document.removeEventListener("mousedown",fn);
  }, []);

  const others   = cards.filter(c=>c.id!==currentId);
  const filtered = q ? others.filter(c=>c.name.toLowerCase().includes(q.toLowerCase())) : others;
  const toggle   = id => onChange(value.includes(id)?value.filter(x=>x!==id):[...value,id]);
  const label    = value.length ? `${value.length} dependencia${value.length>1?"s":""} seleccionada${value.length>1?"s":""}` : "Seleccionar dependencias…";

  return (
    <div ref={ref} style={{position:"relative"}}>
      <button onClick={()=>setOpen(o=>!o)} style={{...INP,textAlign:"left",cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"space-between",color:value.length?"#b8ccd8":"#3a5060"}}>
        <span>{label}</span>
        <span style={{color:"#3a5060",fontSize:"10px"}}>{open?"▲":"▼"}</span>
      </button>
      {open && (
        <div style={{position:"absolute",top:"100%",left:0,right:0,zIndex:200,background:"#0a1520",border:"1px solid #2a3a4a",borderRadius:2,marginTop:2,boxShadow:"0 8px 24px rgba(0,0,0,0.7)",maxHeight:230,display:"flex",flexDirection:"column"}}>
          <div style={{padding:6,borderBottom:"1px solid #1a2a3a",flexShrink:0}}>
            <input value={q} onChange={e=>setQ(e.target.value)} placeholder="Buscar tarea…" autoFocus style={{...INP,padding:"4px 8px",fontSize:"10px"}}/>
          </div>
          <div style={{overflow:"auto",flex:1}}>
            {filtered.length===0 && <div style={{padding:"10px 12px",fontSize:"10px",color:"#3a5060"}}>Sin resultados</div>}
            {filtered.map(c => {
              const row=rows.find(r=>r.id===c.rowId), col=COLS.find(cl=>cl.id===c.colId), sel=value.includes(c.id);
              return (
                <div key={c.id} onClick={()=>toggle(c.id)} style={{padding:"7px 10px",cursor:"pointer",display:"flex",alignItems:"flex-start",gap:8,background:sel?"#0e1e30":"transparent",borderBottom:"1px solid #0e1820"}}>
                  <input type="checkbox" checked={sel} readOnly style={{marginTop:2,accentColor:"#e94560",flexShrink:0,cursor:"pointer"}}/>
                  <div>
                    <div style={{fontSize:"11px",color:sel?"#b8ccd8":"#6a8090",lineHeight:1.3}}>{c.name}</div>
                    <div style={{fontSize:"8px",color:"#2a4060",marginTop:2}}>{row?.name} · <span style={{color:col?.hl||"#4a6a80"}}>{col?.label}</span></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      )}
    </div>
  );
}

// ── Settings panel ────────────────────────────────────────────────────────────
function SettingsPanel({ D, mut, onClose }) {
  const addOwner = () => mut(d=>d.owners.push({id:"o"+uid(),name:"Nuevo responsable",color:"#4488aa"}));
  const upOwner  = (id,k,v) => mut(d=>{const o=d.owners.find(o=>o.id===id);if(o)o[k]=v;});
  const delOwner = id => mut(d=>{if(d.owners.length<=1)return;d.owners=d.owners.filter(o=>o.id!==id);const fb=d.owners[0].id;d.cards=d.cards.map(c=>({...c,ownerId:c.ownerId===id?fb:c.ownerId}));});
  const addTag   = () => mut(d=>d.tags.push({id:"tg"+uid(),name:"Nueva etiqueta",color:"#6688aa"}));
  const upTag    = (id,k,v) => mut(d=>{const t=d.tags.find(t=>t.id===id);if(t)t[k]=v;});
  const delTag   = id => mut(d=>{d.tags=d.tags.filter(t=>t.id!==id);d.cards=d.cards.map(c=>({...c,tagIds:c.tagIds.filter(x=>x!==id)}));});

  return (
    <div style={{width:290,background:"#070d14",borderLeft:"2px solid #1a3050",display:"flex",flexDirection:"column",overflow:"hidden",flexShrink:0}}>
      <div style={{padding:"12px 16px",borderBottom:"1px solid #1a2a3a",display:"flex",justifyContent:"space-between",alignItems:"center",flexShrink:0}}>
        <div style={{fontSize:"10px",letterSpacing:"2px",color:"#4cc9f0"}}>⚙ CONFIGURACIÓN</div>
        <button onClick={onClose} style={{background:"none",border:"none",color:"#445",cursor:"pointer",fontSize:"18px",lineHeight:1,padding:0}}>✕</button>
      </div>
      <div style={{flex:1,overflow:"auto",padding:16,display:"flex",flexDirection:"column",gap:22}}>
        <Section title="OWNERS / RESPONSABLES">
          <div style={{fontSize:"9px",color:"#3a5060",marginBottom:10,lineHeight:1.5}}>Haz clic en el color para personalizarlo.</div>
          {D.owners.map(o=>(
            <div key={o.id} style={{display:"flex",alignItems:"center",gap:6,marginBottom:6}}>
              <input type="color" value={o.color} onChange={e=>upOwner(o.id,"color",e.target.value)} style={{width:28,height:28,border:"1px solid #2a3a4a",background:"none",cursor:"pointer",padding:2,borderRadius:3,flexShrink:0}}/>
              <input value={o.name} onChange={e=>upOwner(o.id,"name",e.target.value)} style={{...INP,flex:1,padding:"4px 7px",borderColor:o.color+"66"}}/>
              <button onClick={()=>delOwner(o.id)} style={{background:"none",border:"1px solid #2a3a4a",color:"#4a5a6a",cursor:"pointer",padding:"3px 7px",borderRadius:2,fontSize:"11px",flexShrink:0}}>✕</button>
            </div>
          ))}
          <button onClick={addOwner} style={{...BTNS,width:"100%",marginTop:4,padding:"7px"}}>+ AÑADIR OWNER</button>
        </Section>

        <Section title="ETIQUETAS">
          <div style={{fontSize:"9px",color:"#3a5060",marginBottom:10,lineHeight:1.5}}>Para filtrar y categorizar entradas.</div>
          {D.tags.map(t=>(
            <div key={t.id} style={{display:"flex",alignItems:"center",gap:6,marginBottom:6}}>
              <input type="color" value={t.color} onChange={e=>upTag(t.id,"color",e.target.value)} style={{width:28,height:28,border:"1px solid #2a3a4a",background:"none",cursor:"pointer",padding:2,borderRadius:3,flexShrink:0}}/>
              <input value={t.name} onChange={e=>upTag(t.id,"name",e.target.value)} style={{...INP,flex:1,padding:"4px 7px",borderColor:t.color+"66"}}/>
              <button onClick={()=>delTag(t.id)} style={{background:"none",border:"1px solid #2a3a4a",color:"#4a5a6a",cursor:"pointer",padding:"3px 7px",borderRadius:2,fontSize:"11px",flexShrink:0}}>✕</button>
            </div>
          ))}
          <button onClick={addTag} style={{...BTNS,width:"100%",marginTop:4,padding:"7px"}}>+ AÑADIR ETIQUETA</button>
        </Section>

        <Section title="COLUMNAS (fijas)">
          <div style={{fontSize:"9px",color:"#3a5060",lineHeight:1.6}}>
            Los 4 pilares del modelo no son editables:<br/><br/>
            {COLS.map(c=><span key={c.id} style={{display:"block",color:c.hl,marginBottom:3}}>→ {c.label}</span>)}
          </div>
        </Section>
      </div>
    </div>
  );
}

// ── Micro components ──────────────────────────────────────────────────────────
function Field({ label, children }) {
  return (
    <div>
      <div style={{fontSize:"7px",letterSpacing:"2px",color:"#3a5060",marginBottom:5}}>{label}</div>
      {children}
    </div>
  );
}
function Section({ title, children }) {
  return (
    <div>
      <div style={{fontSize:"8px",letterSpacing:"3px",color:"#3a5060",marginBottom:10,paddingBottom:6,borderBottom:"1px solid #1a2a3a"}}>{title}</div>
      {children}
    </div>
  );
}
function Pill({ children, color, active, onClick }) {
  return (
    <button onClick={onClick} style={{fontSize:"9px",padding:"3px 9px",borderRadius:20,border:`1.5px solid ${color}`,background:active?color:"transparent",color:active?"#fff":color,cursor:"pointer",transition:"all 0.15s",fontFamily:"inherit",lineHeight:1.4}}>{children}</button>
  );
}
function Divider() {
  return <div style={{width:1,height:32,background:"#1c3050",margin:"0 4px",flexShrink:0}}/>;
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
</script>
</body>
</html>